// ==========================================
// PharmaDerm AI — Rash Analyzer v3
// Google Apps Script (LINE + Gemini 2.5 Flash)
// อัปเกรด: Differential Dx ครบ 5 กลุ่ม + Multi-turn ซักประวัติก่อนวิเคราะห์
// ==========================================

// ==========================================
// 1. ตั้งค่าระบบ — ใส่ค่าจริงตรงนี้
// ==========================================
const LINE_ACCESS_TOKEN = 'ใส่ LINE Channel Access Token ตรงนี้';
const GEMINI_API_KEY    = 'ใส่ Gemini API Key ตรงนี้';

// ==========================================
// 2. Session Store — เก็บ state ผู้ใช้ชั่วคราว
// (Apps Script in-memory: reset ทุก execution แต่เพียงพอสำหรับ flow นี้)
// ใช้ PropertiesService เพื่อ persist ข้าม request
// ==========================================
const SESSION_EXPIRY_MIN = 10; // session หมดอายุใน 10 นาที

function getSession(userId) {
  const props = PropertiesService.getScriptProperties();
  const raw = props.getProperty('session_' + userId);
  if (!raw) return null;
  try {
    const s = JSON.parse(raw);
    // ตรวจ expiry
    if (Date.now() - s.timestamp > SESSION_EXPIRY_MIN * 60 * 1000) {
      props.deleteProperty('session_' + userId);
      return null;
    }
    return s;
  } catch (_) { return null; }
}

function setSession(userId, data) {
  const props = PropertiesService.getScriptProperties();
  props.setProperty('session_' + userId, JSON.stringify({
    ...data,
    timestamp: Date.now()
  }));
}

function clearSession(userId) {
  PropertiesService.getScriptProperties().deleteProperty('session_' + userId);
}

// ==========================================
// 3. Entry Point หลัก
// ==========================================
function doPost(e) {
  let replyToken = "";

  try {
    if (!e || !e.postData || !e.postData.contents) {
      return ContentService.createTextOutput('OK');
    }

    const body  = JSON.parse(e.postData.contents);
    const event = body.events && body.events[0];

    if (!event || !event.replyToken) {
      return ContentService.createTextOutput('OK');
    }

    replyToken  = event.replyToken;
    const userId = event.source && event.source.userId;

    // ─── กรณีส่งรูปภาพ ───
    if (event.type === 'message' && event.message.type === 'image') {
      const session = getSession(userId);

      if (!session || !session.historyCompleted) {
        // ยังไม่มีประวัติ → เริ่ม multi-turn ซักประวัติก่อน
        // เก็บ imageId ไว้รอ แล้วถามคำถามแรก
        setSession(userId, {
          step: 1,
          imageId: event.message.id,
          historyCompleted: false
        });
        replyQuickReply(replyToken,
          "📋 ก่อนวิเคราะห์ ขอซักประวัติสั้นๆ 3 ข้อนะครับ\n\n" +
          "ข้อ 1/3 — ผื่นเริ่มเป็นมานานแค่ไหนครับ?",
          ["< 24 ชั่วโมง", "1–3 วัน", "4–14 วัน", "2–8 สัปดาห์", "นานกว่านั้น"]
        );
      } else {
        // มีประวัติครบแล้ว → วิเคราะห์เลย
        const imageBlob   = getImageFromLine(event.message.id);
        const base64Image = Utilities.base64Encode(imageBlob.getBytes());
        const result      = analyzeWithGemini(base64Image, session.history);
        clearSession(userId);
        replyFlexMessage(replyToken, result);
      }

    // ─── กรณีส่งข้อความ (ตอบคำถาม multi-turn) ───
    } else if (event.type === 'message' && event.message.type === 'text') {
      const text    = event.message.text.trim();
      const session = getSession(userId);

      // ── ไม่มี session → welcome message ──
      if (!session) {
        replyTextMessage(replyToken,
          "👨‍⚕️ PharmaDerm AI v3\n\n" +
          "ส่งรูปภาพผื่นเพื่อเริ่มการวิเคราะห์ครับ\n\n" +
          "📌 Tips ถ่ายรูป:\n" +
          "• ถ่ายระยะใกล้ชัดเจน\n" +
          "• แสงสว่างเพียงพอ\n" +
          "• เห็นลักษณะผื่นครบ"
        );
        return ContentService.createTextOutput('OK');
      }

      // ── step 1: ระยะเวลา ──
      if (session.step === 1) {
        setSession(userId, {
          ...session,
          step: 2,
          q1_duration: text
        });
        replyQuickReply(replyToken,
          "ข้อ 2/3 — ท่านกำลังใช้ยาอยู่หรือเปล่าครับ? (ยาใหม่ที่เพิ่งได้รับใน 2 เดือนที่ผ่านมา)",
          ["ใช่ มียาใหม่", "ใช้ยาเดิมอยู่แล้ว", "ไม่ได้ใช้ยาเลย", "ไม่แน่ใจ"]
        );

      // ── step 2: ประวัติยา ──
      } else if (session.step === 2) {
        setSession(userId, {
          ...session,
          step: 3,
          q2_medication: text
        });
        replyQuickReply(replyToken,
          "ข้อ 3/3 — มีอาการร่วมอื่นไหมครับ?",
          ["ไข้ร่วมด้วย", "คันมาก", "แสบร้อน/เจ็บ", "ไม่มีอาการอื่น"]
        );

      // ── step 3: อาการร่วม → วิเคราะห์เลย ──
      } else if (session.step === 3) {
        const history = {
          duration:   session.q1_duration,
          medication: session.q2_medication,
          symptoms:   text
        };
        setSession(userId, { ...session, step: 4, history, historyCompleted: true });

        replyTextMessage(replyToken,
          "✅ ได้รับข้อมูลครบแล้วครับ\n\n" +
          "📸 กรุณาส่งรูปภาพผื่นได้เลยครับ ระบบจะวิเคราะห์พร้อมกันเลย"
        );

      // ── step 4: รอรูป (กรณีส่งข้อความแทน) ──
      } else if (session.step === 4) {
        replyTextMessage(replyToken, "📸 กรุณาส่ง 'รูปภาพ' ผื่นครับ ยังรอรูปอยู่นะครับ");

      } else {
        clearSession(userId);
        replyTextMessage(replyToken, "📸 กรุณาส่งรูปภาพผื่นเพื่อเริ่มต้นใหม่ครับ");
      }

    } else {
      replyTextMessage(replyToken, "📸 กรุณาส่งรูปภาพผื่นครับ");
    }

    return ContentService.createTextOutput('OK');

  } catch (err) {
    console.error("🔥 CRITICAL ERROR:", err.message, err.stack);
    try {
      if (replyToken) {
        replyTextMessage(replyToken,
          "⚠️ ระบบขัดข้องชั่วคราว กรุณาลองใหม่อีกครั้งครับ\n(Error: " + err.message + ")"
        );
      }
    } catch (_) {}
    return ContentService.createTextOutput('Error: ' + err.message);
  }
}

// ==========================================
// 4. ดึงรูปภาพจาก LINE
// ==========================================
function getImageFromLine(messageId) {
  const url = `https://api-data.line.me/v2/bot/message/${messageId}/content`;
  const res = UrlFetchApp.fetch(url, {
    method: 'get',
    headers: { 'Authorization': `Bearer ${LINE_ACCESS_TOKEN}` },
    muteHttpExceptions: true
  });
  if (res.getResponseCode() !== 200) {
    throw new Error("ดึงรูปภาพจาก LINE ไม่ได้ — ตรวจสอบ LINE_ACCESS_TOKEN");
  }
  return res.getBlob();
}

// ==========================================
// 5. วิเคราะห์ด้วย Gemini 2.5 Flash
//    พร้อม Differential Dx ครบ 5 กลุ่ม + context จากประวัติ
// ==========================================
function analyzeWithGemini(base64Image, history) {
  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${GEMINI_API_KEY}`;

  // ── สร้าง history context ถ้ามี ──
  const historyContext = history
    ? `[Patient History Provided]
- Rash duration: ${history.duration}
- Medication history: ${history.medication}
- Associated symptoms: ${history.symptoms}`
    : `[No history provided — image analysis only]`;

  // ── Prompt หลัก: Differential Dx ครบ 5 กลุ่ม ──
  const prompt = `You are an expert clinical pharmacist and dermatologist working in a Thai district hospital. Your task is to analyze a skin lesion photograph and provide a structured differential diagnosis.

${historyContext}

[DIFFERENTIAL DIAGNOSIS FRAMEWORK — 5 Categories]

Analyze the image against ALL 5 categories and rank by probability:

1. DRUG ERUPTION (ผื่นแพ้ยา)
   Subtypes: MP Rash, Urticaria, Fixed Drug Eruption, SJS/TEN, DRESS, AGEP
   Visual clues: symmetric widespread erythema, mucosal involvement, skin detachment, targetoid lesions
   History clue: new medication in past 8 weeks

2. FUNGAL INFECTION (เชื้อรา)
   Subtypes: Tinea corporis (ringworm), Tinea versicolor, Tinea pedis, Candidiasis
   Visual clues: annular/ring-shaped with central clearing, scaly border, satellite lesions (candida), hypopigmented patches (versicolor)
   History clue: humid environment, immunocompromised

3. INSECT / ARTHROPOD (แมลงและสัตว์ขาข้อ)
   Subtypes: Paederus (ก้นกระดก) — linear vesicular streak, Mosquito — discrete wheals, Scabies — interdigital burrows, Mite
   Visual clues: Paederus = linear vesicles/bullae with "kissing lesion" pattern; Mosquito = discrete urticarial papules; Scabies = burrow lines between fingers/wrists
   History clue: outdoor exposure, nighttime itch (scabies), linear pattern after skin contact

4. CONTACT DERMATITIS (ผื่นสัมผัส)
   Subtypes: Allergic contact dermatitis, Irritant contact dermatitis
   Visual clues: geometric/straight-edged demarcation matching contact area, vesicles/weeping in acute phase, lichenification in chronic
   History clue: new cosmetic/chemical/plant contact, occupational exposure

5. VIRAL EXANTHEM (ผื่นไวรัส)
   Subtypes: Herpes zoster (งูสวัด) — dermatomal vesicles, Herpes simplex — clustered perioral/genital vesicles, Varicella — widespread polymorphic, HFMD — palms/soles/mouth
   Visual clues: dermatomal unilateral vesicles (zoster), clustered vesicles on erythematous base (HSV), centrifugal distribution + all stages simultaneously (varicella)
   History clue: prodromal pain/fever, sick contacts

[DRUG ERUPTION RED FLAGS — if any present → triage RED regardless of primary diagnosis]
- Blistering / bullae / skin detachment (>1% BSA)
- Mucosal involvement (lips, conjunctiva, genitals)
- Facial edema / angioedema
- Purpuric or necrotic lesions
- Diffuse erythema > 30% BSA
- Fever reported with widespread rash

[OUTPUT — respond ONLY with valid raw JSON, no markdown, no explanation]
{
  "image_quality": "GOOD or POOR — reason",
  "lesion_description": "Objective morphology: primary lesion type, distribution, color, pattern, secondary changes, estimated BSA%",

  "differential_diagnosis": [
    {
      "rank": 1,
      "category": "DRUG_ERUPTION | FUNGAL | INSECT | CONTACT | VIRAL",
      "subtype": "specific subtype name",
      "probability": "HIGH | MEDIUM | LOW",
      "supporting_features": "visual + history features that support this",
      "against_features": "features that argue against this"
    },
    {
      "rank": 2,
      "category": "...",
      "subtype": "...",
      "probability": "...",
      "supporting_features": "...",
      "against_features": "..."
    },
    {
      "rank": 3,
      "category": "...",
      "subtype": "...",
      "probability": "...",
      "supporting_features": "...",
      "against_features": "..."
    }
  ],

  "primary_diagnosis": "Most likely diagnosis — category: subtype",
  "is_drug_eruption_suspected": true or false,
  "red_flags_found": ["list each red flag, or empty array []"],
  "triage_level": "RED or YELLOW or GREEN",
  "triage_rationale": "1–2 sentence rationale",
  "pharmacist_action": "Specific pharmacist action based on primary diagnosis",
  "patient_message_th": "ข้อความภาษาไทยแจ้งผลเบื้องต้นและคำแนะนำ เหมาะกับการวินิจฉัยที่น่าจะเป็น",
  "confidence": "HIGH | MEDIUM | LOW — reason"
}`;

  const payload = {
    contents: [{
      parts: [
        { text: prompt },
        { inline_data: { mime_type: "image/jpeg", data: base64Image } }
      ]
    }],
    safetySettings: [
      { category: "HARM_CATEGORY_DANGEROUS_CONTENT", threshold: "BLOCK_ONLY_HIGH" },
      { category: "HARM_CATEGORY_SEXUALLY_EXPLICIT", threshold: "BLOCK_ONLY_HIGH" },
      { category: "HARM_CATEGORY_HARASSMENT",        threshold: "BLOCK_ONLY_HIGH" },
      { category: "HARM_CATEGORY_HATE_SPEECH",       threshold: "BLOCK_ONLY_HIGH" }
    ],
    generationConfig: {
      temperature: 0.1,
      responseMimeType: "application/json"
    }
  };

  const res = UrlFetchApp.fetch(url, {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  });

  const code = res.getResponseCode();
  const text = res.getContentText();

  if (code !== 200) {
    console.error("❌ Gemini API error:", text);
    if (code === 404) throw new Error("Gemini: Model ไม่พบ (404) — ตรวจสอบชื่อ model");
    if (code === 403) throw new Error("Gemini: ไม่มีสิทธิ์ (403) — เปิด API ใน Google Cloud");
    if (code === 429) throw new Error("Gemini: เกิน quota (429) — รอสักครู่");
    throw new Error(`Gemini error ${code}`);
  }

  let resultText = "";
  try {
    const json = JSON.parse(text);
    if (json.promptFeedback && json.promptFeedback.blockReason) {
      throw new Error("Gemini บล็อคภาพนี้: " + json.promptFeedback.blockReason);
    }
    resultText = json.candidates[0].content.parts[0].text;
    resultText = resultText.replace(/```json\s*/gi, '').replace(/```\s*/g, '').trim();
    return JSON.parse(resultText);
  } catch (parseErr) {
    console.error("❌ JSON parse error. Raw:", resultText || text);
    throw new Error("Gemini ส่ง JSON กลับมาผิดรูปแบบ — กรุณาลองใหม่");
  }
}

// ==========================================
// 6. Flex Message — รองรับ Differential Dx
// ==========================================
function replyFlexMessage(replyToken, data) {
  const level = (data.triage_level || "GREEN").toUpperCase();

  // ── Header color & label ──
  let headerColor, headerEmoji, headerLabel;
  if (level === "RED") {
    headerColor = "#C62828"; headerEmoji = "🚨"; headerLabel = "ความเสี่ยงสูง — ส่งพบแพทย์ด่วน";
  } else if (level === "YELLOW") {
    headerColor = "#E65100"; headerEmoji = "⚠️"; headerLabel = "ความเสี่ยงปานกลาง — ติดตามใกล้ชิด";
  } else {
    headerColor = "#2E7D32"; headerEmoji = "🟢"; headerLabel = "ความเสี่ยงต่ำ — ติดตามอาการ";
  }

  // ── Category label map ──
  const catLabel = {
    DRUG_ERUPTION: "💊 ผื่นแพ้ยา",
    FUNGAL:        "🍄 เชื้อรา",
    INSECT:        "🦟 แมลง/สัตว์ขาข้อ",
    CONTACT:       "🖐 ผื่นสัมผัส",
    VIRAL:         "🦠 ไวรัส"
  };

  const probColor = { HIGH: "#C62828", MEDIUM: "#E65100", LOW: "#388E3C" };
  const probLabel = { HIGH: "สูง", MEDIUM: "ปานกลาง", LOW: "ต่ำ" };

  // ── สร้าง differential blocks ──
  const ddx     = data.differential_diagnosis || [];
  const ddxBlocks = [];

  ddx.slice(0, 3).forEach((d, i) => {
    const prob  = (d.probability || "LOW").toUpperCase();
    const color = probColor[prob] || "#757575";
    const label = probLabel[prob] || d.probability;
    const cat   = catLabel[d.category] || d.category;

    ddxBlocks.push({
      type: "box",
      layout: "vertical",
      backgroundColor: i === 0 ? "#FFF3E0" : "#FAFAFA",
      cornerRadius: "8px",
      paddingAll: "10px",
      margin: "sm",
      contents: [
        {
          type: "box",
          layout: "horizontal",
          contents: [
            {
              type: "text",
              text: `${i + 1}. ${cat}`,
              weight: "bold",
              size: "sm",
              color: i === 0 ? "#BF360C" : "#424242",
              flex: 4
            },
            {
              type: "text",
              text: `โอกาส: ${label}`,
              size: "xs",
              color: color,
              align: "end",
              flex: 3,
              weight: "bold"
            }
          ]
        },
        {
          type: "text",
          text: d.subtype || "-",
          size: "xs",
          color: "#757575",
          margin: "xs",
          wrap: true
        },
        {
          type: "text",
          text: `✔ ${d.supporting_features || "-"}`,
          size: "xs",
          color: "#4CAF50",
          margin: "xs",
          wrap: true
        }
      ]
    });
  });

  // ── Red flags ──
  const redFlagsText = (data.red_flags_found && data.red_flags_found.length > 0)
    ? data.red_flags_found.join(", ")
    : "ไม่พบ";

  // ── Drug eruption alert banner (แสดงเฉพาะถ้าสงสัย) ──
  const drugAlertBlock = data.is_drug_eruption_suspected
    ? [{
        type: "box",
        layout: "horizontal",
        backgroundColor: "#FFEBEE",
        cornerRadius: "6px",
        paddingAll: "10px",
        contents: [
          { type: "text", text: "⚠️ สงสัยผื่นแพ้ยา — ตรวจสอบประวัติยาด่วน", size: "xs", color: "#B71C1C", wrap: true, weight: "bold" }
        ]
      }]
    : [];

  const confidenceMap = { HIGH: "สูง", MEDIUM: "ปานกลาง", LOW: "ต่ำ" };
  const confidenceLabel = confidenceMap[(data.confidence || "").split(" ")[0]] || "-";

  const flexBody = {
    type: "bubble",
    size: "mega",
    header: {
      type: "box",
      layout: "vertical",
      backgroundColor: headerColor,
      paddingAll: "16px",
      contents: [
        { type: "text", text: `${headerEmoji} PharmaDerm AI v3`, color: "#FFFFFF", size: "lg", weight: "bold" },
        { type: "text", text: headerLabel, color: "#FFCCBC", size: "sm", margin: "xs", wrap: true }
      ]
    },
    body: {
      type: "box",
      layout: "vertical",
      paddingAll: "14px",
      spacing: "sm",
      contents: [

        // ── วินิจฉัยหลัก ──
        {
          type: "box",
          layout: "vertical",
          backgroundColor: "#E8F5E9",
          cornerRadius: "8px",
          paddingAll: "12px",
          contents: [
            { type: "text", text: "🎯 วินิจฉัยเบื้องต้นที่น่าจะเป็น", weight: "bold", size: "sm", color: "#1B5E20" },
            { type: "text", text: data.primary_diagnosis || "-", size: "sm", wrap: true, margin: "sm", color: "#2E7D32", weight: "bold" }
          ]
        },

        // ── Drug alert banner ──
        ...drugAlertBlock,

        // ── Differential Dx ──
        {
          type: "box",
          layout: "vertical",
          backgroundColor: "#F5F5F5",
          cornerRadius: "8px",
          paddingAll: "10px",
          contents: [
            { type: "text", text: "📊 Differential Diagnosis (Top 3)", weight: "bold", size: "sm", color: "#424242" },
            ...ddxBlocks
          ]
        },

        // ── Red flags ──
        {
          type: "box",
          layout: "vertical",
          backgroundColor: level === "RED" ? "#FFEBEE" : "#F5F5F5",
          cornerRadius: "8px",
          paddingAll: "10px",
          contents: [
            { type: "text", text: "🚩 Drug Eruption Red Flags", weight: "bold", size: "sm", color: "#B71C1C" },
            { type: "text", text: redFlagsText, size: "xs", wrap: true, margin: "xs", color: "#616161" }
          ]
        },

        // ── Pharmacist action ──
        {
          type: "box",
          layout: "vertical",
          backgroundColor: "#FFF8E1",
          cornerRadius: "8px",
          paddingAll: "10px",
          contents: [
            { type: "text", text: "💊 การดำเนินการ (เภสัชกร)", weight: "bold", size: "sm", color: "#E65100" },
            { type: "text", text: data.pharmacist_action || "-", size: "sm", wrap: true, margin: "xs", color: "#BF360C" }
          ]
        },

        // ── ข้อความผู้ป่วย ──
        {
          type: "box",
          layout: "vertical",
          backgroundColor: "#F3E5F5",
          cornerRadius: "8px",
          paddingAll: "10px",
          contents: [
            { type: "text", text: "💬 ข้อความถึงผู้ป่วย", weight: "bold", size: "sm", color: "#6A1B9A" },
            { type: "text", text: data.patient_message_th || "-", size: "sm", wrap: true, margin: "xs", color: "#7B1FA2" }
          ]
        },

        // ── Footer ──
        { type: "separator", margin: "sm" },
        {
          type: "box",
          layout: "horizontal",
          margin: "sm",
          contents: [
            { type: "text", text: `ความเชื่อมั่น AI: ${confidenceLabel}`, size: "xs", color: "#9E9E9E", flex: 1 },
            { type: "text", text: `รูป: ${data.image_quality ? data.image_quality.split(" ")[0] : "-"}`, size: "xs", color: "#9E9E9E", align: "end", flex: 1 }
          ]
        },
        {
          type: "text",
          text: "⚕️ ประเมินโดย AI — ต้องผ่านการยืนยันจากเภสัชกรหรือแพทย์เสมอ",
          size: "xs", color: "#BDBDBD", wrap: true, margin: "xs"
        }
      ]
    }
  };

  const body = {
    replyToken: replyToken,
    messages: [{
      type: "flex",
      altText: `${headerEmoji} PharmaDerm AI — ${data.primary_diagnosis || "ผลวิเคราะห์"} | ${level}`,
      contents: flexBody
    }]
  };

  const res = UrlFetchApp.fetch('https://api.line.me/v2/bot/message/reply', {
    method: 'post',
    headers: { 'Authorization': `Bearer ${LINE_ACCESS_TOKEN}` },
    contentType: 'application/json',
    payload: JSON.stringify(body),
    muteHttpExceptions: true
  });

  if (res.getResponseCode() !== 200) {
    console.error("❌ LINE Flex reply error:", res.getContentText());
    throw new Error("ส่ง Flex Message กลับ LINE ไม่ได้");
  }
}

// ==========================================
// 7. Quick Reply Message (สำหรับ multi-turn)
// ==========================================
function replyQuickReply(replyToken, text, items) {
  const quickReplyItems = items.map(label => ({
    type: "action",
    action: { type: "message", label: label, text: label }
  }));

  const body = {
    replyToken: replyToken,
    messages: [{
      type: "text",
      text: text,
      quickReply: { items: quickReplyItems }
    }]
  };

  const res = UrlFetchApp.fetch('https://api.line.me/v2/bot/message/reply', {
    method: 'post',
    headers: { 'Authorization': `Bearer ${LINE_ACCESS_TOKEN}` },
    contentType: 'application/json',
    payload: JSON.stringify(body),
    muteHttpExceptions: true
  });

  if (res.getResponseCode() !== 200) {
    console.error("❌ LINE quickReply error:", res.getContentText());
  }
}

// ==========================================
// 8. Text Message ธรรมดา (fallback)
// ==========================================
function replyTextMessage(replyToken, text) {
  const body = {
    replyToken: replyToken,
    messages: [{ type: 'text', text: text }]
  };
  UrlFetchApp.fetch('https://api.line.me/v2/bot/message/reply', {
    method: 'post',
    headers: { 'Authorization': `Bearer ${LINE_ACCESS_TOKEN}` },
    contentType: 'application/json',
    payload: JSON.stringify(body),
    muteHttpExceptions: true
  });
}

// ==========================================
// 9. Diagnostic Test
// ==========================================
function testSystem() {
  console.log("═══════════════════════════════════════");
  console.log("  PharmaDerm AI v3 — System Diagnostic");
  console.log("═══════════════════════════════════════");

  // LINE Token
  if (!LINE_ACCESS_TOKEN || LINE_ACCESS_TOKEN.includes('ใส่')) {
    console.error("❌ LINE_ACCESS_TOKEN: ยังไม่ได้ใส่ค่า!");
  } else {
    const r = UrlFetchApp.fetch('https://api.line.me/v2/bot/info', {
      headers: { 'Authorization': `Bearer ${LINE_ACCESS_TOKEN}` },
      muteHttpExceptions: true
    });
    if (r.getResponseCode() === 200) {
      console.log(`✅ LINE Token: ผ่าน (Bot: ${JSON.parse(r.getContentText()).displayName})`);
    } else {
      console.error(`❌ LINE Token: พัง! Code ${r.getResponseCode()}`);
    }
  }

  // Gemini Key
  if (!GEMINI_API_KEY || GEMINI_API_KEY.includes('ใส่')) {
    console.error("❌ GEMINI_API_KEY: ยังไม่ได้ใส่ค่า!");
  } else {
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${GEMINI_API_KEY}`;
    const r = UrlFetchApp.fetch(url, {
      method: 'post',
      contentType: 'application/json',
      payload: JSON.stringify({ contents: [{ parts: [{ text: "Reply OK" }] }] }),
      muteHttpExceptions: true
    });
    if (r.getResponseCode() === 200) {
      console.log("✅ Gemini 2.5 Flash: ผ่าน (AI พร้อมวิเคราะห์)");
    } else {
      console.error(`❌ Gemini Key: พัง! Code ${r.getResponseCode()}`);
    }
  }

  // PropertiesService
  try {
    PropertiesService.getScriptProperties().setProperty('_test', '1');
    PropertiesService.getScriptProperties().deleteProperty('_test');
    console.log("✅ PropertiesService: ผ่าน (Multi-turn session พร้อมใช้)");
  } catch (_) {
    console.error("❌ PropertiesService: ไม่สามารถเข้าถึงได้ — ตรวจสอบสิทธิ์ Script");
  }

  console.log("═══════════════════════════════════════");
  console.log("  เสร็จสิ้น");
  console.log("═══════════════════════════════════════");
}
